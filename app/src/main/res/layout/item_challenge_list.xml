<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="24dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/card_stroke"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_icon_container"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#3A3A3C"
            app:strokeWidth="0dp"
            android:layout_marginEnd="16dp">

            <ImageView
                android:id="@+id/icon_challenge"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_leaf"
                app:tint="@color/emerald_green"
                android:contentDescription="@string/challenges" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="2dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/text_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ios_blue"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true" />

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:background="@color/text_tertiary"
                    android:layout_marginHorizontal="8dp"
                    android:backgroundTint="@color/text_tertiary" />

                <TextView
                    android:id="@+id/text_points"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/emerald_green"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_complete"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="@string/complete"
            android:textSize="12sp"
            app:cornerRadius="22dp"
            android:layout_marginStart="12dp"
            android:backgroundTint="#34C759"
            android:textColor="@color/white"
            android:paddingHorizontal="12dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
